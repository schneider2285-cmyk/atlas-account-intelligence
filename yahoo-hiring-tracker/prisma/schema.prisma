generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Auth (NextAuth) ────────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Core Entities ──────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  role          UserRole  @default(MEMBER)

  accounts     Account[]
  sessions     Session[]
  submissions  Submission[]
  activities   ActivityLog[]
  chatMessages ChatMessage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum UserRole {
  ADMIN
  MEMBER
}

enum BusinessUnit {
  MAIL
  HOME_ECO
  PARANOIDS
  SPORTS
  SEARCH
  ADS
  OTHER
}

enum JobStatus {
  ACTIVE
  ON_HOLD
  FUTURE_NEED
  CANCELLED
  FINDING_TALENT
  ENGAGEMENT_COMPLETED
  ROLE_CANCELLED
}

model Job {
  id              String       @id @default(cuid())
  roleTitle       String
  businessUnit    BusinessUnit
  projectName     String
  yahooPoC        String
  openHeadcount   Int          @default(1)
  sowNumber       String?
  poNumber        String?
  rateCap         Decimal?     @db.Decimal(10, 2)
  toptalJobLink   String?
  salesforceLink  String?
  slackChannel    String?
  interviewerEmails    String?  @db.Text
  interviewPrepNotes   String?  @db.Text
  approvedLocations    String?  @db.Text
  status          JobStatus    @default(ACTIVE)
  dateOpened      DateTime     @default(now())
  matcher         String?

  submissions  Submission[]
  activities   ActivityLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([businessUnit])
  @@index([status])
  @@index([projectName])
}

model Candidate {
  id                String  @id @default(cuid())
  name              String
  toptalProfileLink String?
  location          String?
  city              String?
  country           String?
  rate              Decimal? @db.Decimal(10, 2)
  pstOverlap        String?
  address           String?
  phone             String?
  email             String?

  submissions Submission[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([name])
}

enum SubmissionStatus {
  INTRODUCED
  INTERVIEWING
  INTERVIEW_SCHEDULED
  PENDING_DECISION
  PENDING_2ND_INTERVIEW
  HIRED
  REJECTED
  WITHDRAWN
  REMOVED_FOR_LOCATION
  FINDING_TALENT
  CONSIDER_FOR_OTHER_ROLE
  TALENT_NO_LONGER_AVAILABLE
  TALENT_WITHDRAWN
}

model Submission {
  id                      String           @id @default(cuid())
  jobId                   String
  candidateId             String
  status                  SubmissionStatus @default(INTRODUCED)
  dateIntroduced          DateTime         @default(now())
  dateLastStatusChange    DateTime         @default(now())
  dateLastClientFeedback  DateTime?
  interviewDateTime       DateTime?
  clientFeedbackNotes     String?          @db.Text
  candidateIntroMessage   String?          @db.Text
  createdById             String?

  job       Job       @relation(fields: [jobId], references: [id], onDelete: Cascade)
  candidate Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  createdBy User?     @relation(fields: [createdById], references: [id], onDelete: SetNull)

  activities ActivityLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([jobId])
  @@index([candidateId])
  @@index([status])
}

// ─── Supporting Tables ──────────────────────────────────────────────

model ActivityLog {
  id         String   @id @default(cuid())
  action     String
  entityType String
  entityId   String
  details    Json?
  userId     String?
  jobId      String?
  submissionId String?

  user       User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  job        Job?        @relation(fields: [jobId], references: [id], onDelete: SetNull)
  submission Submission? @relation(fields: [submissionId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([entityType, entityId])
  @@index([createdAt])
  @@index([jobId])
}

model ApprovedCountry {
  id                         String  @id @default(cuid())
  region                     String
  country                    String
  maxDurationMonths          Int?
  requiresAdditionalApproval Boolean @default(false)

  @@unique([region, country])
}

model ChatMessage {
  id        String   @id @default(cuid())
  userId    String
  role      String   // "user" | "assistant"
  content   String   @db.Text
  toolCalls Json?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}
